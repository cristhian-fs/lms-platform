{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown && cp -r ../../packages/db/src/migrations dist/migrations",
    "seed": "tsx src/migrate-and-seed.ts",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.mjs"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1019.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/node": "^1.3.1",
    "@lms-platform/api": "workspace:*",
    "@lms-platform/auth": "workspace:*",
    "@lms-platform/db": "workspace:*",
    "@lms-platform/env": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "drizzle-orm": "^0.45.1",
    "elysia": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@lms-platform/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "^0.16.5",
    "tsx": "^4.19.2",
    "typescript": "^5"
  }
}
